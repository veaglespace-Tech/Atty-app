generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  SUBADMIN
  TEAM_LEADER
  MEMBER
}

enum UserStatus {
  APPROVED
  PENDING
  REJECTED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
}

enum TicketStatus {
  PENDING
  RESOLVED
  CLOSED
}

enum PostType {
  ARTICLE
  POLL
  NOTIFICATION
  TOURNAMENT_CARD
}

model Organization {
  id                 Int       @id @default(autoincrement())
  name               String
  organizationCode   String    @unique
  email              String    @unique
  phone              String
  country            String    @default("India")
  latitude           Float
  longitude          Float
  attendanceRadius   Int       @default(25)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionExpiry DateTime?
  planId             Int?
  orgAdminId         Int?      @unique
  subscriptionId     Int?      @unique
  isActive           Boolean   @default(true)
  isBlocked          Boolean   @default(false)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  plan               Plan?         @relation(fields: [planId], references: [id])
  orgAdmin           User?         @relation("OrganizationPrimaryAdmin", fields: [orgAdminId], references: [id])
  activeSubscription Subscription? @relation("OrganizationActiveSubscription", fields: [subscriptionId], references: [id])

  users              User[]
  members            OrganizationMember[]
  teams              Team[]
  attendances        Attendance[]
  subscriptions      Subscription[] @relation("OrganizationSubscriptions")
  payments           Payment[]
  posts              Post[]

  @@index([subscriptionStatus, subscriptionExpiry])
  @@index([isActive, isBlocked, deletedAt])
}

model User {
  id        Int      @id @default(autoincrement())
  orgId     Int?
  name      String
  email     String   @unique
  mobile    String
  password  String
  status    UserStatus @default(APPROVED)
  isActive  Boolean    @default(true)
  resetTokenHash   String?
  resetTokenExpiry DateTime?
  lastLoginAt DateTime?
  createdById Int?
  deletedAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id])
  memberships OrganizationMember[]
  attendances Attendance[] @relation("AttendanceUser")

  @@index([orgId, status])
}

model OrganizationMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  orgId     Int
  role      UserRole @default(MEMBER)
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId, role])
}

model Team {
  id          Int    @id @default(autoincrement())
  orgId       Int
  name        String
  leaderId    Int?
  createdById Int
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  leader       User?        @relation("TeamLeader", fields: [leaderId], references: [id])
  createdBy    User         @relation("TeamCreatedBy", fields: [createdById], references: [id])

  members      TeamMember[]
  attendances  Attendance[]

  @@unique([orgId, name])
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  userId    Int
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  orgId     Int
  userId    Int
  date      DateTime
  punchInAt  DateTime?
  punchOutAt DateTime?
  totalMinutesWorked Int @default(0)
  status AttendanceStatus @default(PRESENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation("AttendanceUser", fields: [userId], references: [id])

  @@unique([orgId, userId, date])
}

model Plan {
  id             Int      @id @default(autoincrement())
  name           String
  code           String   @unique
  price          Decimal  @db.Decimal(10,2)
  durationInDays Int
  isActive       Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations Organization[]
}

model Subscription {
  id        Int      @id @default(autoincrement())
  orgId     Int
  planId    Int
  amount    Decimal  @db.Decimal(10,2)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdById Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation("OrganizationSubscriptions", fields: [orgId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
}

model Payment {
  id             Int      @id @default(autoincrement())
  orgId          Int
  userId         Int
  subscriptionId Int
  amount         Decimal  @db.Decimal(10,2)
  status         PaymentStatus @default(CREATED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

model Post {
  id       Int      @id @default(autoincrement())
  orgId    Int
  authorId Int
  title    String
  content  String @db.Text
  type     PostType @default(NOTIFICATION)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  author       User         @relation(fields: [authorId], references: [id])
}

model SupportTicket {
  id      Int @id @default(autoincrement())
  name    String
  email   String
  status  TicketStatus @default(PENDING)
  message String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 