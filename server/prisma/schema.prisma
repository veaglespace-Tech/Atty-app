generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  SUB_ADMIN
  TEAM_LEADER
  MEMBER
}

enum UserStatus {
  APPROVED
  PENDING
  REJECTED
  BLOCKED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
  REFUNDED
}

enum PostType {
  NOTIFICATION
  NEWS
  POLL
}

enum SupportTicketStatus {
  OPEN
  CLOSED
  IN_PROGRESS
}

enum VerificationStatus {
  CONTACT_PENDING
  EMAIL_PENDING
  VERIFIED
  CONSUMED
  EXPIRED
}

model ArchiveOrg {
  id                 Int       @id @default(autoincrement())
  orgId              Int?
  planId             Int?
  subscriptionId     Int?

  name               String?
  organizationCode   String?
  email              String?
  phone              String?
  phoneCountryCode   String?
  address            String?
  city               String?
  state              String?
  country            String?
  latitude           Float?
  longitude          Float?
  attendanceRadius   Int?

  subscriptionStatus SubscriptionStatus?
  subscriptionExpiry DateTime?
  isActive           Boolean?
  isBlocked          Boolean?
  archiveReason      String    @default("")
  metadata           Json?

  archivedById       Int?
  archivedAt         DateTime  @default(now())
  originalCreatedAt  DateTime?
  originalUpdatedAt  DateTime?
  deletedAt          DateTime?

  @@index([archivedAt])
  @@index([email])
  @@index([orgId])
  @@index([organizationCode])
  @@map("archive_org")
}

model ArchiveUser {
  id                Int       @id @default(autoincrement())
  userId            Int?
  orgId             Int?

  name              String?
  email             String?
  mobile            String?
  mobileCountryCode String?
  password          String?
  role              UserRole?
  permissions       Json?

  status            UserStatus?
  isActive          Boolean?
  lastLoginAt       DateTime?
  archiveReason     String    @default("")
  metadata          Json?

  createdById       Int?
  archivedById      Int?
  archivedAt        DateTime  @default(now())
  originalCreatedAt DateTime?
  originalUpdatedAt DateTime?
  deletedAt         DateTime?

  @@index([archivedAt])
  @@index([email])
  @@index([orgId, role])
  @@index([userId])
  @@map("archive_user")
}

model Attendance {
  id                    Int       @id @default(autoincrement())
  orgId                 Int
  userId                Int
  teamId                Int?
  markedById            Int?

  date                  String
  punchInAt             DateTime?
  punchOutAt            DateTime?
  punchInLatitude       Float?
  punchInLongitude      Float?
  punchOutLatitude      Float?
  punchOutLongitude     Float?
  punchInDistanceMeters Float?
  punchOutDistanceMeters Float?
  isPunchInValid        Boolean   @default(false)
  isPunchOutValid       Boolean   @default(false)

  totalMinutesWorked    Int                @default(0)
  lateMinutes           Int                @default(0)
  status                AttendanceStatus   @default(PRESENT)
  notes                 String             @default("")
  punchInLocationMeta   Json?
  punchOutLocationMeta  Json?
  punchInSelfieUrl      String?
  punchInSelfiePublicId String?
  punchOutSelfieUrl     String?
  punchOutSelfiePublicId String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  organization Organization @relation(fields: [orgId], references: [id], map: "Attendance_orgId_fkey")
  user         User         @relation("AttendanceUser", fields: [userId], references: [id], map: "Attendance_userId_fkey")
  markedBy     User?        @relation("AttendanceMarkedBy", fields: [markedById], references: [id], map: "Attendance_markedById_fkey")
  team         Team?        @relation(fields: [teamId], references: [id], map: "Attendance_teamId_fkey")

  @@unique([orgId, userId, date], map: "Attendance_orgId_userId_date_key")
  @@index([markedById], map: "Attendance_markedById_fkey")
  @@index([orgId, date], map: "Attendance_orgId_date_idx")
  @@index([orgId, status, date], map: "Attendance_orgId_status_date_idx")
  @@index([orgId, teamId, date], map: "Attendance_orgId_teamId_date_idx")
  @@index([teamId], map: "Attendance_teamId_fkey")
  @@index([userId, date], map: "Attendance_userId_date_idx")
  @@map("attendance")
}

model ContactInquiry {
  id                          Int       @id @default(autoincrement())
  name                        String
  email                       String
  subject                     String
  message                     String    @db.Text
  status                      String    @default("NEW")

  adminNotificationSentAt     DateTime?
  adminNotificationError      String?
  requesterNotificationSentAt DateTime?
  requesterNotificationError  String?

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([createdAt])
  @@index([email, createdAt])
  @@index([status])
  @@map("contact_inquiry")
}

model FreeTrialClaim {
  id         Int      @id @default(autoincrement())
  orgName    String?
  orgEmail   String   @unique
  adminName  String?
  adminEmail String   @unique
  adminPhone String   @unique

  planCode   String
  startDate  DateTime
  endDate    DateTime
  claimedAt  DateTime @default(now())

  @@index([claimedAt])
  @@index([endDate])
  @@map("free_trial_claim")
}

model Organization {
  id                 Int       @id @default(autoincrement())
  orgAdminId         Int?      @unique(map: "Organization_orgAdminId_key")
  planId             Int?
  subscriptionId     Int?      @unique(map: "Organization_subscriptionId_key")

  name               String
  organizationCode   String    @unique(map: "Organization_organizationCode_key")
  email              String    @unique(map: "Organization_email_key")
  phone              String
  phoneCountryCode   String?
  address            String?
  city               String?
  state              String?
  country            String    @default("India")

  latitude           Float
  longitude          Float
  attendanceRadius   Int                @default(25)

  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionExpiry DateTime?
  isActive           Boolean   @default(true)
  isBlocked          Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  plan               Plan?         @relation(fields: [planId], references: [id], map: "Organization_planId_fkey")
  orgAdmin           User?         @relation("OrganizationPrimaryAdmin", fields: [orgAdminId], references: [id], map: "Organization_orgAdminId_fkey")
  activeSubscription Subscription? @relation("OrganizationActiveSubscription", fields: [subscriptionId], references: [id], map: "Organization_subscriptionId_fkey")

  users        User[]               @relation("OrganizationUsers")
  members      OrganizationMember[]
  teams        Team[]
  attendances  Attendance[]
  subscriptions Subscription[]      @relation("OrganizationSubscriptions")
  payments     Payment[]
  posts        Post[]

  @@index([isActive, isBlocked, deletedAt], map: "Organization_isActive_isBlocked_deletedAt_idx")
  @@index([planId], map: "Organization_planId_idx")
  @@index([subscriptionStatus, subscriptionExpiry], map: "Organization_subscriptionStatus_subscriptionExpiry_idx")
  @@map("organization")
}

model OrganizationMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  orgId     Int

  role      UserRole @default(MEMBER)
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId, role])
  @@index([userId])
  @@map("organizationmember")
}

model Payment {
  id                Int      @id @default(autoincrement())
  orgId             Int
  userId            Int
  subscriptionId    Int

  planName          String
  planCode          String
  amount            Float
  currency          String   @default("INR")
  gateway           String   @default("RAZORPAY")
  razorpayOrderId   String
  razorpayPaymentId String?
  razorpaySignature String?

  status            PaymentStatus @default(CREATED)
  failureReason     String        @default("")
  rawResponse       Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], map: "Payment_orgId_fkey")
  user         User         @relation(fields: [userId], references: [id], map: "Payment_userId_fkey")
  subscription Subscription @relation(fields: [subscriptionId], references: [id], map: "Payment_subscriptionId_fkey")

  @@index([orgId, createdAt], map: "Payment_orgId_createdAt_idx")
  @@index([orgId], map: "Payment_orgId_idx")
  @@index([planCode, status, createdAt], map: "Payment_planCode_status_createdAt_idx")
  @@index([razorpayOrderId], map: "Payment_razorpayOrderId_idx")
  @@index([status], map: "Payment_status_idx")
  @@index([subscriptionId], map: "Payment_subscriptionId_idx")
  @@index([userId], map: "Payment_userId_fkey")
  @@map("payment")
}

model Plan {
  id             Int      @id @default(autoincrement())
  name           String
  code           String   @unique(map: "Plan_code_key")
  description    String   @default("")
  price          Float
  currency       String   @default("INR")
  durationInDays Int

  features       Json
  maxUsers       Int      @default(0)
  maxTeams       Int      @default(0)
  maxLocations   Int      @default(0)
  memberLimit    Int      @default(0)

  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizations Organization[]
  subscriptions Subscription[]

  @@map("plan")
}

model Post {
  id        Int      @id @default(autoincrement())
  orgId     Int
  authorId  Int

  title     String
  content   String   @db.Text
  type      PostType @default(NOTIFICATION)
  metadata  Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], map: "posts_orgId_fkey")
  author       User         @relation("PostAuthor", fields: [authorId], references: [id], map: "posts_authorId_fkey")

  @@index([authorId], map: "posts_authorId_idx")
  @@index([orgId, isActive], map: "posts_orgId_isActive_idx")
  @@index([type], map: "posts_type_idx")
  @@map("post")
}

model Subscription {
  id                Int      @id @default(autoincrement())
  orgId             Int
  planId            Int?
  createdById       Int

  planName          String
  planCode          String
  amount            Float
  currency          String   @default("INR")

  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime @default(now())
  endDate           DateTime?
  activeKey         String?  @unique(map: "Subscription_activeKey_key")

  paymentGateway    String   @default("RAZORPAY")
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  notes             String   @default("")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization         Organization  @relation("OrganizationSubscriptions", fields: [orgId], references: [id], map: "Subscription_orgId_fkey")
  activeForOrganization Organization? @relation("OrganizationActiveSubscription")
  plan                 Plan?         @relation(fields: [planId], references: [id], map: "Subscription_planId_fkey")
  createdBy            User          @relation("SubscriptionCreatedBy", fields: [createdById], references: [id], map: "Subscription_createdById_fkey")
  payments             Payment[]

  @@index([createdById], map: "Subscription_createdById_idx")
  @@index([orgId, createdAt], map: "Subscription_orgId_createdAt_idx")
  @@index([orgId, status, endDate], map: "Subscription_orgId_status_endDate_idx")
  @@index([planCode, status], map: "Subscription_planCode_status_idx")
  @@index([planId], map: "Subscription_planId_fkey")
  @@index([razorpayOrderId], map: "Subscription_razorpayOrderId_idx")
  @@index([status, createdAt], map: "Subscription_status_createdAt_idx")
  @@map("subscription")
}

model SupportTicket {
  id        Int      @id @default(autoincrement())
  orgId     Int?
  userId    Int?

  name      String
  email     String
  role      UserRole @default(MEMBER)
  subject   String   @default("Support Query")
  message   String   @db.Text
  status    SupportTicketStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId], map: "support_tickets_orgId_idx")
  @@index([status], map: "support_tickets_status_idx")
  @@map("support_ticket")
}

model Team {
  id               Int      @id @default(autoincrement())
  orgId            Int
  leaderId         Int?
  createdById      Int

  name             String
  description      String   @default("")
  latitude         Float?
  longitude        Float?
  attendanceRadius Int      @default(25)

  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  organization Organization @relation(fields: [orgId], references: [id], map: "Team_orgId_fkey")
  leader       User?        @relation("TeamLeader", fields: [leaderId], references: [id], map: "Team_leaderId_fkey")
  createdBy    User         @relation("TeamCreatedBy", fields: [createdById], references: [id], map: "Team_createdById_fkey")
  members      TeamMember[]
  attendances  Attendance[]

  @@unique([orgId, name], map: "Team_orgId_name_key")
  @@index([createdById], map: "Team_createdById_idx")
  @@index([leaderId], map: "Team_leaderId_idx")
  @@index([orgId, deletedAt], map: "Team_orgId_deletedAt_idx")
  @@map("team")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  userId    Int

  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade, map: "TeamMember_teamId_fkey")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "TeamMember_userId_fkey")

  @@unique([teamId, userId], map: "TeamMember_teamId_userId_key")
  @@index([userId], map: "TeamMember_userId_idx")
  @@map("teammember")
}

model User {
  id                   Int      @id @default(autoincrement())
  orgId                Int?
  createdById          Int?

  name                 String
  email                String   @unique(map: "User_email_key")
  mobile               String
  mobileCountryCode    String?
  password             String
  role                 UserRole   @default(MEMBER)
  permissions          Json?
  resetTokenHash       String?
  resetTokenExpiry     DateTime?

  status               UserStatus @default(APPROVED)
  isActive             Boolean    @default(true)
  lastLoginAt          DateTime?
  profileImageUrl      String?
  profileImagePublicId String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  organization                Organization?        @relation("OrganizationUsers", fields: [orgId], references: [id], map: "User_orgId_fkey")
  memberships                 OrganizationMember[]
  attendances                 Attendance[]         @relation("AttendanceUser")
  markedAttendances           Attendance[]         @relation("AttendanceMarkedBy")
  payments                    Payment[]
  subscriptions               Subscription[]       @relation("SubscriptionCreatedBy")
  posts                       Post[]               @relation("PostAuthor")
  teamMemberships             TeamMember[]
  teamsLed                    Team[]               @relation("TeamLeader")
  createdTeams                Team[]               @relation("TeamCreatedBy")
  primaryAdminForOrganization Organization?        @relation("OrganizationPrimaryAdmin")
  createdUsers                User[]               @relation("UserCreatedBy")
  createdBy                   User?                @relation("UserCreatedBy", fields: [createdById], references: [id], map: "User_createdById_fkey")

  @@index([createdById], map: "User_createdById_idx")
  @@index([orgId, deletedAt], map: "User_orgId_deletedAt_idx")
  @@index([orgId, role], map: "User_orgId_role_idx")
  @@index([orgId, status], map: "User_orgId_status_idx")
  @@map("user")
}

model VerificationSession {
  id                   Int      @id @default(autoincrement())
  purpose              String   @default("MEMBER_REGISTRATION")

  email                String
  phoneE164            String
  countryCode          String?
  nationalNumber       String

  status               VerificationStatus @default(CONTACT_PENDING)
  contactOtpHash       String?
  contactOtpExpiresAt  DateTime
  contactOtpAttempts   Int      @default(0)
  contactOtpLastSentAt DateTime?
  contactVerifiedAt    DateTime?
  emailOtpHash         String?
  emailOtpExpiresAt    DateTime?
  emailOtpAttempts     Int      @default(0)
  emailOtpLastSentAt   DateTime?
  emailVerifiedAt      DateTime?
  consumedAt           DateTime?
  expiresAt            DateTime

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([consumedAt], map: "VerificationSession_consumedAt_idx")
  @@index([email], map: "VerificationSession_email_idx")
  @@index([expiresAt], map: "VerificationSession_expiresAt_idx")
  @@index([phoneE164], map: "VerificationSession_phoneE164_idx")
  @@index([purpose], map: "VerificationSession_purpose_idx")
  @@index([status, expiresAt], map: "VerificationSession_status_expiresAt_idx")
  @@index([status], map: "VerificationSession_status_idx")
  @@index([email, phoneE164, purpose, createdAt], map: "verification_lookup_idx")
  @@map("verificationsession")
}
