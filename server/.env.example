# Shared defaults only.
# Copy this file to `.env.local` for local-only secrets and machine-specific values.
# `.env.local` overrides `.env` locally and is ignored by git.

# Environment Configuration
NODE_ENV=development
PORT=5000

# Client
CLIENT_URL=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/veagle_attendee

# JWT
JWT_KEY=replace-with-strong-secret
SESSION_TOKEN_TTL_HOURS=24
LOGIN_RATE_LIMIT_MAX=10

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email Configuration
EMAIL=
EMAIL_PASS=
EMAIL_USER=
EMAIL_FROM_NAME=Veagle Attendee
SUPPORT_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_SERVICE=

# AI API (Cerebras)
CEREBRAS_API_KEY=

# Cloud Storage (Cloudinary)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PROFILE_IMAGE_FOLDER=veagle-attendee/profile-images
CLOUDINARY_ATTENDANCE_SELFIE_FOLDER=veagle-attendee/attendance-selfies

ATTENDANCE_TIMEZONE=Asia/Kolkata
ATTENDANCE_START_TIME=09:30
ATTENDANCE_LATE_GRACE_MINUTES=0
ATTENDANCE_SELFIE_MAX_BYTES=3145728
PROFILE_IMAGE_MAX_BYTES=2097152

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Test-only: keep false/empty in development and production
BYPASS_PROTECTED_ROUTES=false
