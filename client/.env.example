# Highest priority override (optional):
# NEXT_PUBLIC_API_URL=https://api.example.com/api

# Auto-select API URL by runtime host:
# - Local hostnames (localhost, 127.x.x.x, LAN IPs) -> NEXT_PUBLIC_API_URL_LOCAL
# - Non-local hostnames -> NEXT_PUBLIC_API_URL_PROD
NEXT_PUBLIC_API_URL_LOCAL=http://localhost:5000/api
NEXT_PUBLIC_API_URL_PROD=https://atty.veaglespace.com/api

# The base URL of the frontend application for generating referral links.
# If left blank, it will automatically use the browser's current domain name.
# NEXT_PUBLIC_REFERRAL_LINK=https://atty.veaglespace.com/register/organisation
