# Shared defaults only.
# Copy this file to `.env.local` for local-only secrets and machine-specific values.
# `.env.local` overrides `.env` locally and is ignored by git.

# Environment Configuration
NODE_ENV=development
PORT=5000

# Client
CLIENT_URL=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For a public IP deployment, append your frontend origin here.
# Example: http://YOUR_PUBLIC_IP:3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/veagle_attendee

# JWT
JWT_KEY=replace-with-strong-secret
SESSION_TOKEN_TTL_HOURS=24
LOGIN_RATE_LIMIT_MAX=10


# Email Configuration
EMAIL_FROM_NAME=Veagle Attendee
SUPPORT_EMAIL=atty@info.veaglespace.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_DAILY_LIMIT=100
EMAIL_QUOTA_TIMEZONE=Asia/Kolkata

# Hostinger mailbox pool
# Each mailbox is used for outgoing mail until it reaches EMAIL_DAILY_LIMIT for the day.
EMAIL_1=atty@info.veaglespace.com
EMAIL_1_PASSWORD=
