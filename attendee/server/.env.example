# AI API (Cerebras)
CEREBRAS_API_KEY=

# Cloud Storage (ImageKit)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PROFILE_IMAGE_FOLDER=veagle-attendee/profile-images
IMAGEKIT_ATTENDANCE_SELFIE_FOLDER=veagle-attendee/attendance-selfies
IMAGEKIT_POST_ATTACHMENT_FOLDER=veagle-attendee/post-attachments

ATTENDANCE_TIMEZONE=Asia/Kolkata
ATTENDANCE_START_TIME=09:30
ATTENDANCE_LATE_GRACE_MINUTES=0
ATTENDANCE_SELFIE_MAX_BYTES=3145728
PROFILE_IMAGE_MAX_BYTES=2097152

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Test-only: keep false/empty in development and production
BYPASS_PROTECTED_ROUTES=false
